{
    "statusLine": {
        "type": "command",
        "command": "ccusage statusline"
    },
    "hooks": {
        "Notification": [
          {
            "matcher": "",
            "hooks": [
              {
                "type": "command",
                "command": "osascript -e 'display notification \"Claude Code Notification\" with title \"Claude Code\" sound name \"Submarine\"'"
              }
            ]
          }
        ],
        "Stop": [
          {
            "matcher": "",
            "hooks": [
              {
                "type": "command",
                "command": "osascript -e 'display notification \"Claude Code Stopped\" with title \"Claude Code\" sound name \"Glass\"'"
              }
            ]
          }
        ]
    }
}
